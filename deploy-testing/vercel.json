{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "selmamoraes.com.br" }],
      "destination": "https://www.selmamoraes.com.br/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/diagnostico", "destination": "/diagnostico.html" },
    { "source": "/diagnostico.html", "destination": "/diagnostico.html" },
    { "source": "/logo-preview", "destination": "/logo-preview.html" },
    { "source": "/logo-preview.html", "destination": "/logo-preview.html" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.webmanifest" },
    { "source": "/icon-192.svg", "destination": "/icon-192.svg" },
    { "source": "/icon-512.svg", "destination": "/icon-512.svg" },
    { "source": "/logo-sm-header.png", "destination": "/logo-sm-header.png" },
    { "source": "/logo-sm-footer.png", "destination": "/logo-sm-footer.png" },
    { "source": "/logo-sm-favicon.png", "destination": "/logo-sm-favicon.png" },
    { "source": "/selma-photo.png", "destination": "/selma-photo.png" },
    { "source": "/earth-texture.jpg", "destination": "/earth-texture.jpg" },
    { "source": "/(.*\\.(png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|js|css|map))", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://formsubmit.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    }
  ]
}

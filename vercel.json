{
  "buildCommand": "",
  "outputDirectory": "deploy-testing",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "selmamoraes.com.br" }],
      "destination": "https://www.selmamoraes.com.br/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/cotacao", "destination": "/cotacao.html" },
    { "source": "/cotacao.html", "destination": "/cotacao.html" },
    { "source": "/avaliacao", "destination": "/diagnostico.html" },
    { "source": "/diagnostico", "destination": "/diagnostico.html" },
    { "source": "/diagnostico.html", "destination": "/diagnostico.html" },
    { "source": "/painel-selma", "destination": "/painel-selma.html" },
    { "source": "/painel-selma.html", "destination": "/painel-selma.html" },
    { "source": "/checklist-nr1", "destination": "/checklist-nr1.html" },
    { "source": "/checklist-nr1.html", "destination": "/checklist-nr1.html" },
    { "source": "/guia-calendly", "destination": "/guia-calendly.html" },
    { "source": "/guia-calendly.html", "destination": "/guia-calendly.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/", "destination": "/blog/index.html" },
    { "source": "/blog/nr1-o-que-mudou-2026", "destination": "/blog/nr1-o-que-mudou-2026.html" },
    { "source": "/blog/nr1-o-que-mudou-2026.html", "destination": "/blog/nr1-o-que-mudou-2026.html" },
    { "source": "/blog/frprt-explicado", "destination": "/blog/frprt-explicado.html" },
    { "source": "/blog/frprt-explicado.html", "destination": "/blog/frprt-explicado.html" },
    { "source": "/blog/multa-nr1-2026", "destination": "/blog/multa-nr1-2026.html" },
    { "source": "/blog/multa-nr1-2026.html", "destination": "/blog/multa-nr1-2026.html" },
    { "source": "/blog/_template.css", "destination": "/blog/_template.css" },
    { "source": "/logo-preview", "destination": "/logo-preview.html" },
    { "source": "/logo-preview.html", "destination": "/logo-preview.html" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.webmanifest" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/icon-192.svg", "destination": "/icon-192.svg" },
    { "source": "/icon-512.svg", "destination": "/icon-512.svg" },
    { "source": "/icon-192.png", "destination": "/icon-192.png" },
    { "source": "/icon-512.png", "destination": "/icon-512.png" },
    { "source": "/apple-touch-icon.png", "destination": "/apple-touch-icon.png" },
    { "source": "/apple-touch-icon-152.png", "destination": "/apple-touch-icon-152.png" },
    { "source": "/apple-touch-icon-167.png", "destination": "/apple-touch-icon-167.png" },
    { "source": "/favicon-32.png", "destination": "/favicon-32.png" },
    { "source": "/logo-sm-header.png", "destination": "/logo-sm-header.png" },
    { "source": "/logo-sm-footer.png", "destination": "/logo-sm-footer.png" },
    { "source": "/logo-sm-favicon.png", "destination": "/logo-sm-favicon.png" },
    { "source": "/logo-sm-header-cutout.png", "destination": "/logo-sm-header-cutout.png" },
    { "source": "/logo-sm-footer-cutout.png", "destination": "/logo-sm-footer-cutout.png" },
    { "source": "/logo-sm-cutout.png", "destination": "/logo-sm-cutout.png" },
    { "source": "/logo-sm-monogram.png", "destination": "/logo-sm-monogram.png" },
    { "source": "/selma-photo.png", "destination": "/selma-photo.png" },
    { "source": "/earth-texture.jpg", "destination": "/earth-texture.jpg" },
    { "source": "/:path*.:ext(png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|js|css|map)", "destination": "/:path*.:ext" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://i.ytimg.com https://img.youtube.com; connect-src 'self' https://formsubmit.co; frame-src https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    }
  ]
}
